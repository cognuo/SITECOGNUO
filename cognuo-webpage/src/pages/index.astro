---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { niches } from '../data/niches';

const capabilities = [
  'Automação com IA',
  'Software sob medida',
  'Agentes IA',
  'Integrações',
  'Sistemas internos',
];

const stats = [
  { value: '8 sem', label: 'e seu processo já está rodando diferente' },
  { value: '70%',   label: 'do tempo operacional que as empresas economizam' },
  { value: '100%',  label: 'do código e dos dados pertencem a você' },
  { value: '24h',   label: 'para responder qualquer dúvida ou ajuste' },
];

const problems = [
  { title: 'Sua equipe refaz o mesmo trabalho todo dia',        cost: 'Horas que poderiam ir para o que importa', icon: 'repeat' },
  { title: 'As informações ficam presas nas pessoas',           cost: 'Tudo depende de quem está disponível',     icon: 'scatter' },
  { title: 'Quando a demanda cresce, o custo também',           cost: 'Não escala sem contratar mais',            icon: 'stack' },
  { title: 'Cada sistema faz uma coisa, mas não se falam',      cost: 'Alguém sempre faz a ponte manualmente',   icon: 'broken' },
  { title: 'Cliente espera. Equipe acumula. Ninguém dá conta',  cost: 'Experiência cai, cliente vai embora',     icon: 'clock' },
  { title: 'Você decide sem ver os números em tempo real',      cost: 'Apaga incêndio em vez de evitar',         icon: 'chart' },
];

const solutions = [
  {
    title: 'Pare de fazer o que um sistema faz melhor',
    desc: 'Identificamos as tarefas que consomem mais tempo da sua equipe e construímos o processo automatizado que as substitui. Sem precisar contratar ninguém.',
    before: 'Pessoa fazendo tarefa repetitiva',
    after:  'Processo rodando sozinho',
    outcome: 'Equipe livre para o que importa',
    icon: 'ai',
  },
  {
    title: 'Um sistema feito para o seu negócio',
    desc: 'Seu processo não precisa se adaptar a uma ferramenta genérica. Construímos exatamente o que sua operação precisa, do jeito que ela funciona.',
    before: 'Gambiarras em cima de ferramentas',
    after:  'Sistema que encaixa no seu processo',
    outcome: 'Sem adaptações forçadas',
    icon: 'blueprint',
  },
  {
    title: 'Atendimento que não para quando sua equipe para',
    desc: 'Seus clientes recebem resposta imediata a qualquer hora. Quando realmente precisam de uma pessoa, o sistema encaminha. Sem fila, sem espera.',
    before: 'Fila acumulando, cliente esperando',
    after:  'Resposta na hora, todo dia',
    outcome: 'Cliente satisfeito sem custo extra',
    icon: 'agent',
  },
  {
    title: 'Chega de Excel como sistema de gestão',
    desc: 'Construímos a ferramenta interna que sua equipe vai querer usar. Tudo no lugar certo, sem precisar perguntar para ninguém onde está a informação.',
    before: 'Excel, WhatsApp e e-mail como ERP',
    after:  'Uma tela, tudo que precisa',
    outcome: 'Informação acessível para todos',
    icon: 'dashboard',
  },
  {
    title: 'Seus sistemas finalmente conversando',
    desc: 'Não precisamos substituir o que já funciona. Conectamos o que você já usa para que a informação flua sem ninguém precisar copiar de um lugar para o outro.',
    before: 'Alguém sempre fazendo a ponte',
    after:  'Sistemas sincronizados, dados limpos',
    outcome: 'Sem retrabalho, sem inconsistência',
    icon: 'nodes',
  },
];

const steps = [
  { num: '01', title: 'A gente ouve primeiro',   duration: '45 min',     desc: 'Entendemos seu negócio, seus gargalos e o que está custando mais caro, antes de falar em solução.' },
  { num: '02', title: 'Mostramos o plano',        duration: '3 a 5 dias', desc: 'Você recebe uma proposta clara: o que vamos construir, quanto vai custar e quando vai estar pronto.' },
  { num: '03', title: 'Construímos junto com você', duration: '4 a 12 sem', desc: 'A cada 2 semanas você vê o que foi construído e pode dar retorno. Sem surpresas no final.' },
  { num: '04', title: 'Vai ao ar',               duration: '1 semana',   desc: 'Seu processo novo funcionando. Sua equipe operando diferente desde o primeiro dia.' },
  { num: '05', title: 'Cresce com você',          duration: 'Contínuo',   desc: 'À medida que seu negócio muda, o sistema evolui. Estamos aqui para o longo prazo.' },
];

const differentials = [
  { title: 'Feito para você, não para todo mundo',  them: 'Ferramenta genérica que você dobra para caber', us: 'Sistema construído para o seu processo exato' },
  { title: 'Você vê resultado antes de terminar',   them: 'Entrega só no final, com surpresas',            us: 'Algo funcionando a cada 2 semanas' },
  { title: 'Não substituímos o que já funciona',    them: 'Joga fora e começa do zero',                    us: 'Conectamos o que você já tem' },
  { title: 'IA onde resolve de verdade',            them: 'IA como item no pitch',                         us: 'Aplicada só onde gera resultado real' },
  { title: 'O sistema é seu, para sempre',          them: 'Preso a uma plataforma que pode te cobrar mais', us: 'Código, dados e servidor pertencem a você' },
  { title: 'Cresce sem precisar trocar tudo',       them: 'Funciona agora, quebra quando escala',          us: 'Pensado para aguentar o crescimento' },
];

const caseMetrics = [
  { label: 'Esforço operacional',    value: '-70%',        bar: 70,  highlight: true },
  { label: 'Tempo de resposta',      value: 'Instantâneo', bar: 95 },
  { label: 'Escalada para humano',   value: '18%',         bar: 18 },
  { label: 'Até produção',           value: '8 semanas',   bar: 40 },
];

const faqs = [
  {
    q: 'O que acontece na conversa gratuita?',
    a: 'A gente passa 45 minutos entendendo o seu negócio: como você opera hoje, onde está perdendo tempo ou dinheiro e o que poderia ser diferente. No final, você já sai com clareza sobre o que dá para resolver, mesmo que não feche nada com a gente.',
  },
  {
    q: 'Quanto custa?',
    a: 'Depende do que precisa ser feito. Depois da conversa inicial, enviamos uma proposta com valor e prazo definidos. Sem surpresa no meio do caminho. Projetos menores e automações pontuais costumam ter um custo de entrada bem acessível.',
  },
  {
    q: 'Quanto tempo até eu ver resultado?',
    a: 'Para automações e projetos menores, as primeiras entregas funcionando em 4 a 8 semanas. Para sistemas maiores, você vê algo real a cada 2 semanas desde o início. Não espera o projeto inteiro terminar para ver o que foi feito.',
  },
  {
    q: 'Vocês conseguem conectar com o que já usamos?',
    a: 'Sim. Trabalhamos para não substituir o que já funciona. Conectamos com ERPs, CRMs, plataformas de atendimento e qualquer sistema que permita integração. Na maioria dos casos você não precisa trocar nada do que já tem.',
  },
  {
    q: 'A IA que vocês usam realmente funciona?',
    a: 'Funciona onde faz sentido. Não colocamos IA em tudo só para parecer moderno. Aplicamos onde ela resolve um problema real: responder clientes, classificar informações, extrair dados de documentos. Se não agregar resultado, não usamos.',
  },
  {
    q: 'O sistema fica sendo nosso ou de vocês?',
    a: 'Seu. Tudo que construímos (o código, os dados, o servidor) pertence à sua empresa. Você pode continuar com a gente, levar para outro time ou tocar internamente. Sem nenhuma dependência.',
  },
  {
    q: 'Dá para começar pequeno e crescer depois?',
    a: 'Sempre. A maioria dos projetos começa resolvendo um problema específico e cresce a partir daí. Construímos pensando no longo prazo, mas entregando valor desde a primeira semana.',
  },
  {
    q: 'E depois que o projeto termina?',
    a: 'Oferecemos suporte e evolução contínua. Seu negócio muda, o sistema muda junto. Muitos clientes trabalham com a gente por anos, não só para um projeto.',
  },
];
---

<Layout
  title="Cognuo | Software sob medida e automações com IA"
  description="Desenvolvemos sistemas sob medida, automações inteligentes e integrações com IA que eliminam processos manuais e reduzem custos operacionais."
>
  <Navbar />

  <!-- ═══ HERO ═══════════════════════════════════════════════════════ -->
  <section class="hero-root relative min-h-[90vh] lg:min-h-[820px] overflow-hidden flex flex-col" style="background:#0C0B10;">
    <div class="absolute inset-0 hero-grid-cols" aria-hidden="true"></div>
    <div class="absolute inset-0 hero-grid-dots opacity-60" aria-hidden="true"></div>
    <div class="hero-orb hero-orb-2" aria-hidden="true"></div>
    <div class="hero-orb hero-orb-1" aria-hidden="true"></div>
    <div class="hero-spotlight" aria-hidden="true"></div>
    <div class="hero-accent-line" aria-hidden="true"></div>

    <div class="relative z-10 flex-1 flex items-center justify-center px-6 py-28 lg:py-24">
      <div class="grid lg:grid-cols-[1fr_1.15fr] gap-14 items-center max-w-6xl mx-auto w-full">
        <div class="text-center lg:text-left">

          <div class="anim-hero anim-d1 inline-flex items-center gap-2.5 mb-10">
            <span class="hidden lg:inline-block w-6 h-px bg-off-white/35" aria-hidden="true"></span>
            <span class="text-[10.5px] font-medium tracking-[0.2em] uppercase text-off-white/55">
              Para empresas que cresceram além da planilha
            </span>
          </div>

          <h1 class="anim-hero anim-d2 text-[clamp(2rem,4.2vw,3.4rem)] font-bold text-off-white leading-[1.1] tracking-[-0.02em] mb-6 max-w-[22ch]">
            Sua operação merece funcionar sem depender de você.
          </h1>

          <p class="anim-hero anim-d3 text-[1.02rem] sm:text-[1.08rem] text-off-white/70 max-w-[540px] lg:max-w-[500px] mx-auto lg:mx-0 leading-[1.7] mb-10">
            Construímos os sistemas que eliminam o trabalho repetitivo,
            conectam o que está desconectado e deixam sua equipe
            focada no que realmente faz a empresa crescer.
          </p>

          <div class="anim-hero anim-d4 flex flex-wrap items-center justify-center lg:justify-start gap-3 mb-8">
            <a href="/contato" class="hero-cta-primary">
              <span>Agendar diagnóstico gratuito</span>
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                <path d="M3 7h8m0 0L7 3m4 4-4 4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
            <a href="#processo" class="hero-cta-secondary">Ver como trabalhamos</a>
          </div>

          <div class="anim-hero anim-d4 flex flex-wrap items-center justify-center lg:justify-start gap-x-4 gap-y-2 text-[11px] uppercase tracking-[0.15em] text-off-white/65 font-medium">
            <span>45 minutos</span>
            <span class="w-px h-3 bg-off-white/28" aria-hidden="true"></span>
            <span>Sem compromisso</span>
            <span class="w-px h-3 bg-off-white/28" aria-hidden="true"></span>
            <span>Resposta em 24h</span>
          </div>
        </div>

        <!-- Hero figure: system / agent diagram -->
        <div class="anim-hero anim-d3 hidden lg:block relative">
          <div class="hero-figure">
            <div class="hf-core">
              <div class="hf-core-label">Sistema sob medida</div>
              <div class="hf-core-sub">IA + Integrações + Dados</div>
              <div class="hf-pulse" aria-hidden="true"></div>
            </div>

            <div class="hf-node hf-node-a">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="16" rx="2"/><path d="M3 10h18"/></svg>
              <span>CRM</span>
            </div>
            <div class="hf-node hf-node-b">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M3 5v6c0 1.66 4 3 9 3s9-1.34 9-3V5"/><path d="M3 11v6c0 1.66 4 3 9 3s9-1.34 9-3v-6"/></svg>
              <span>ERP</span>
            </div>
            <div class="hf-node hf-node-c">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
              <span>Atendimento</span>
            </div>
            <div class="hf-node hf-node-d">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/></svg>
              <span>APIs</span>
            </div>
            <div class="hf-node hf-node-e">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18"/><path d="M7 14l4-4 3 3 5-6"/></svg>
              <span>Dashboard</span>
            </div>

            <svg class="hf-wires" viewBox="0 0 400 400" aria-hidden="true">
              <defs>
                <linearGradient id="wg" x1="0" y1="0" x2="1" y2="0">
                  <stop offset="0" stop-color="#0035B0" stop-opacity="0"/>
                  <stop offset="0.5" stop-color="#3B6CE0" stop-opacity="0.55"/>
                  <stop offset="1" stop-color="#0035B0" stop-opacity="0"/>
                </linearGradient>
              </defs>
              <path d="M200 200 L  80  100" stroke="url(#wg)" stroke-width="1" fill="none"/>
              <path d="M200 200 L 320  100" stroke="url(#wg)" stroke-width="1" fill="none"/>
              <path d="M200 200 L  80  300" stroke="url(#wg)" stroke-width="1" fill="none"/>
              <path d="M200 200 L 320  300" stroke="url(#wg)" stroke-width="1" fill="none"/>
              <path d="M200 200 L 200  40"  stroke="url(#wg)" stroke-width="1" fill="none"/>
            </svg>
          </div>
        </div>
      </div>
    </div>

    <div class="relative z-10 pb-6 text-center">
      <a href="#sobre" class="inline-flex flex-col items-center gap-1.5 text-[10px] uppercase tracking-[0.22em] text-off-white/50 hover:text-off-white/80 transition-colors">
        <span>Role</span>
        <span class="inline-block hero-scroll-chev" aria-hidden="true">
          <svg width="10" height="10" viewBox="0 0 12 12" fill="none">
            <path d="M6 1v10m0 0L1.5 6.5M6 11l4.5-4.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </span>
      </a>
    </div>
  </section>

  <!-- ═══ STATS STRIP ══════════════════════════════════════════════════ -->
  <section aria-label="Números" class="bg-secondary border-t border-off-white/10 py-12">
    <div class="max-w-7xl mx-auto px-6 lg:px-10">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-10 lg:gap-14">
        {stats.map((s, i) => (
          <div class="relative" data-animate data-animate-delay={String(Math.min(i, 3))}>
            <p class="text-[clamp(2rem,3.4vw,2.8rem)] font-extrabold text-off-white leading-none tracking-tight mb-2">
              {s.value}
            </p>
            <p class="text-[11px] uppercase tracking-[0.14em] text-off-white/55 leading-relaxed">
              {s.label}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ WHAT WE DO (strip) ═══════════════════════════════════════════ -->
  <section aria-label="O que fazemos" class="bg-secondary border-t border-off-white/10 py-7">
    <div class="max-w-7xl mx-auto px-6 lg:px-10">
      <div class="flex flex-wrap items-center justify-center gap-x-5 gap-y-3">
        <span class="text-[10px] font-semibold uppercase tracking-[0.22em] text-off-white/60">
          O que fazemos
        </span>
        <span class="w-px h-3 bg-off-white/22 hidden sm:inline-block" aria-hidden="true"></span>
        {capabilities.map((cap, i) => (
          <>
            <span class="text-[13px] font-medium text-off-white/85">{cap}</span>
            {i < capabilities.length - 1 && (
              <span class="text-off-white/35 select-none" aria-hidden="true">·</span>
            )}
          </>
        ))}
        <span class="w-px h-3 bg-off-white/22 hidden lg:inline-block" aria-hidden="true"></span>
        <a href="#solucoes" class="hidden lg:inline-flex items-center gap-1.5 text-[12px] font-medium text-off-white/75 hover:text-off-white transition-colors group">
          <span>Ver em detalhe</span>
          <span class="transition-transform group-hover:translate-x-0.5" aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ═══ AUTHORITY + FRAGMENTED → UNIFIED FIGURE ═══════════════════ -->
  <section id="sobre" class="bg-off-white py-28 lg:py-36 border-b border-secondary/8">
    <div class="max-w-7xl mx-auto px-6 lg:px-10 grid lg:grid-cols-[1fr_1fr] gap-16 items-center">
      <div data-animate>
        <div class="flex items-center gap-3 mb-8">
          <span class="text-[10px] font-semibold tracking-[0.22em] text-primary uppercase">01 / Posicionamento</span>
          <span class="h-px flex-1 bg-secondary/12 max-w-[80px]" aria-hidden="true"></span>
        </div>
        <p class="text-[clamp(1.6rem,3.1vw,2.6rem)] font-bold text-secondary leading-[1.18] tracking-tight">
          Você não tem um problema de tecnologia.<br />
          Tem um processo que cresceu além do <span class="underline decoration-primary decoration-[3px] underline-offset-[6px]">improviso</span>.
        </p>
        <p class="mt-6 text-[1.02rem] text-secondary/65 max-w-xl leading-relaxed">
          Em algum momento, toda empresa que cresce chega no limite do que dá
          para fazer no Excel, no WhatsApp e nos acordos verbais. É nesse ponto
          que a gente entra para construir o sistema que vai sustentar o
          próximo nível do seu negócio.
        </p>
        <a href="/contato" class="inline-flex items-center gap-2 mt-10 text-sm font-medium text-primary group">
          <span class="border-b border-primary/40 pb-px group-hover:border-primary transition-colors">Solicitar diagnóstico gratuito</span>
          <span class="transition-transform group-hover:translate-x-1" aria-hidden="true">→</span>
        </a>
      </div>

      <!-- Before/After figure -->
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 sm:gap-5" data-animate data-animate-delay="2">
        <div class="pos-card pos-before">
          <p class="pos-label">Antes</p>
          <div class="pos-chaos">
            <span class="pos-chip" style="top:14%; left:10%;">Planilha</span>
            <span class="pos-chip" style="top:28%; right:8%;">ERP</span>
            <span class="pos-chip" style="top:48%; left:22%;">CRM</span>
            <span class="pos-chip" style="top:64%; right:18%;">WhatsApp</span>
            <span class="pos-chip" style="top:80%; left:8%;">E-mail</span>
            <span class="pos-chip" style="top:80%; right:10%;">PDF</span>
            <svg class="pos-lines" viewBox="0 0 200 200" aria-hidden="true">
              <path d="M30 40 L 160 60 L 60 110 L 170 130 L 50 170 L 150 180" stroke="currentColor" stroke-width="0.7" fill="none" stroke-dasharray="3 3"/>
            </svg>
          </div>
          <p class="pos-caption">Ilhas que não conversam</p>
        </div>

        <div class="pos-card pos-after">
          <p class="pos-label">Depois</p>
          <div class="pos-unified">
            <div class="pos-hub">Sistema único</div>
            <span class="pos-sat pos-sat-1">Dados</span>
            <span class="pos-sat pos-sat-2">IA</span>
            <span class="pos-sat pos-sat-3">APIs</span>
            <span class="pos-sat pos-sat-4">UI</span>
            <svg class="pos-rings" viewBox="0 0 200 200" aria-hidden="true">
              <circle cx="100" cy="100" r="60" stroke="currentColor" stroke-width="0.8" fill="none" opacity="0.25"/>
              <circle cx="100" cy="100" r="86" stroke="currentColor" stroke-width="0.8" fill="none" opacity="0.15"/>
            </svg>
          </div>
          <p class="pos-caption">Uma fonte da verdade</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ PROBLEMS ═══════════════════════════════════════════════════ -->
  <section class="bg-off-white py-24 lg:py-32">
    <div class="max-w-7xl mx-auto px-6 lg:px-10">
      <div class="flex items-center gap-3 mb-6" data-animate>
        <span class="text-[10px] font-semibold tracking-[0.22em] text-primary uppercase">02 / Problemas</span>
        <span class="h-px flex-1 bg-secondary/12 max-w-[80px]" aria-hidden="true"></span>
      </div>
      <h2 class="text-[clamp(1.65rem,2.6vw,2.25rem)] font-bold text-secondary leading-tight tracking-tight mb-3 max-w-xl" data-animate>
        Sua operação está no limite quando...
      </h2>
      <p class="text-secondary/65 max-w-xl mb-14 text-[0.98rem] leading-relaxed" data-animate data-animate-delay="1">
        Cada um desses sinais tem um custo real: em horas, em dinheiro e no quanto sua equipe aguenta.
      </p>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
        {problems.map((problem, i) => (
          <div class="problem-card group" data-animate data-animate-delay={String(Math.min(i, 3))}>
            <div class="problem-icon" aria-hidden="true">
              {problem.icon === 'repeat' && (
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 2l4 4-4 4"/><path d="M3 11v-1a4 4 0 014-4h14"/><path d="M7 22l-4-4 4-4"/><path d="M21 13v1a4 4 0 01-4 4H3"/></svg>
              )}
              {problem.icon === 'scatter' && (
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="5" cy="6" r="1.5"/><circle cx="18" cy="8" r="1.5"/><circle cx="7" cy="16" r="1.5"/><circle cx="17" cy="18" r="1.5"/><circle cx="12" cy="11" r="1.5"/></svg>
              )}
              {problem.icon === 'stack' && (
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
              )}
              {problem.icon === 'broken' && (
