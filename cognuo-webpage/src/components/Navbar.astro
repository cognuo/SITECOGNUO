---
const mobileLinks = [
  { href: '#solucoes', label: 'Soluções' },
  { href: '#processo', label: 'Processo' },
  { href: '#cases',    label: 'Cases' },
  { href: '#sobre',    label: 'Sobre' },
  { href: '/contato',  label: 'Contato' },
];
---
<header id="navbar" class="fixed top-0 left-0 right-0 z-[60] transition-all duration-500">
  <div class="nav-accent" aria-hidden="true"></div>

  <div class="max-w-[1400px] mx-auto px-6 lg:px-10">
    <nav class="flex items-center justify-between h-[72px] relative">

      <div class="flex items-center gap-5 relative z-[60]">
        <a href="/" class="flex items-center group" aria-label="Cognuo, página inicial">
          <img
            src="/images/logo_with_text_white.png"
            alt="Cognuo"
            class="h-[22px] w-auto transition-opacity duration-300 group-hover:opacity-80"
            width="132"
            height="22"
            fetchpriority="high"
            decoding="async"
          />
        </a>

        <div class="hidden lg:flex items-center gap-3 pl-5 border-l border-white/10">
          <span class="text-[11px] font-medium text-white/70">
            Sistemas que trabalham por você
          </span>
        </div>
      </div>

      <div class="hidden md:flex absolute left-1/2 -translate-x-1/2 items-center gap-0.5">
        <a href="#solucoes" class="nav-link">Soluções</a>
        <a href="#processo" class="nav-link">Processo</a>
        <a href="#cases"    class="nav-link">Cases</a>
        <a href="#sobre"    class="nav-link">Sobre</a>
      </div>

      <div class="hidden md:flex items-center gap-6 relative z-10">
        <a href="/contato" class="text-[12.5px] font-medium text-white/50 hover:text-white transition-colors duration-200">
          Contato
        </a>
        <a href="/contato" class="cta-primary group">
          <span>Falar com especialista</span>
          <svg width="13" height="13" viewBox="0 0 14 14" fill="none" class="transition-transform duration-300 group-hover:translate-x-[3px]" aria-hidden="true">
            <path d="M3 7h8m0 0L7 3m4 4-4 4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>

      <button
        id="menu-toggle"
        class="md:hidden relative z-[60] w-10 h-10 -mr-2 flex items-center justify-center text-white/85 transition-colors"
        aria-label="Abrir menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <span class="hamburger" aria-hidden="true">
          <span class="hamburger-line"></span>
          <span class="hamburger-line"></span>
        </span>
      </button>
    </nav>
  </div>
</header>

<div
  id="mobile-menu"
  class="mobile-menu md:hidden"
  aria-hidden="true"
>
    <div class="mobile-menu-bg" aria-hidden="true"></div>

    <div class="mobile-menu-inner">
      <p class="mm-eyebrow">Menu</p>

      <ul class="mm-list">
        {mobileLinks.map((link, i) => (
          <li style={`--i: ${i}`}>
            <a href={link.href} class="mm-link" data-menu-link>
              <span class="mm-num">{String(i + 1).padStart(2, '0')}</span>
              <span class="mm-text">{link.label}</span>
              <span class="mm-arrow" aria-hidden="true">
                <svg width="18" height="12" viewBox="0 0 18 12" fill="none"><path d="M1 6h15m0 0L11 1m5 5l-5 5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </span>
            </a>
          </li>
        ))}
      </ul>

      <div class="mm-footer">
        <a href="/contato" class="mm-cta" data-menu-link>
          <span>Falar com especialista</span>
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
            <path d="M3 7h8m0 0L7 3m4 4-4 4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
        <p class="mm-meta">Software sob medida · Automação &amp; IA · Brasil</p>
      </div>
    </div>
  </div>

<style>
  #navbar {
    transition: background-color 0.4s ease, backdrop-filter 0.4s ease, border-color 0.4s ease;
  }

  #navbar.scrolled {
    background: rgba(23, 22, 27, 0.72);
    backdrop-filter: blur(18px) saturate(180%);
    -webkit-backdrop-filter: blur(18px) saturate(180%);
    border-bottom: 1px solid rgba(250, 250, 250, 0.06);
  }

  .nav-accent {
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent 0%,
      rgba(0, 53, 176, 0) 18%,
      rgba(0, 53, 176, 0.55) 50%,
      rgba(0, 53, 176, 0) 82%,
      transparent 100%
    );
    opacity: 0;
    transition: opacity 0.5s ease;
    pointer-events: none;
  }

  #navbar.scrolled .nav-accent { opacity: 1; }

  .nav-link {
    position: relative;
    padding: 0.55rem 0.95rem;
    font-size: 12.5px;
    font-weight: 500;
    letter-spacing: -0.005em;
    color: rgba(250, 250, 250, 0.58);
    transition: color 0.2s ease;
  }
  .nav-link::before {
    content: '';
    position: absolute;
    inset: 4px 0;
    background: rgba(250, 250, 250, 0.045);
    opacity: 0;
    transition: opacity 0.25s ease;
    border-radius: 3px;
  }
  .nav-link::after {
    content: '';
    position: absolute;
    bottom: 9px;
    left: 50%;
    transform: translateX(-50%);
    width: 0;
    height: 1px;
    background: #0035B0;
    transition: width 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .nav-link:hover { color: rgba(250, 250, 250, 1); }
  .nav-link:hover::before { opacity: 1; }
  .nav-link:hover::after { width: 16px; }

  .cta-primary {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.6rem 1.1rem;
    background: #0035B0;
    color: #FAFAFA;
    font-size: 12.5px;
    font-weight: 500;
    letter-spacing: -0.005em;
    transition: background-color 0.25s ease, box-shadow 0.35s ease, transform 0.2s ease;
    box-shadow:
      inset 0 1px 0 0 rgba(255, 255, 255, 0.09),
      0 0 0 1px rgba(0, 53, 176, 0),
      0 0 0 0 rgba(0, 53, 176, 0);
  }
  .cta-primary:hover {
    background: #0040d4;
    box-shadow:
      inset 0 1px 0 0 rgba(255, 255, 255, 0.14),
      0 0 0 1px rgba(0, 64, 212, 0.6),
      0 10px 32px -6px rgba(0, 53, 176, 0.55);
  }
  .cta-primary:active { transform: translateY(1px); }

  /* ─── Hamburger icon ─── */
  .hamburger {
    position: relative;
    width: 22px;
    height: 12px;
    display: inline-block;
  }
  .hamburger-line {
    position: absolute;
    left: 0;
    width: 100%;
    height: 1.5px;
    background: currentColor;
    border-radius: 2px;
    transition: transform 0.45s cubic-bezier(0.7, 0, 0.2, 1),
                top 0.3s cubic-bezier(0.7, 0, 0.2, 1);
  }
  .hamburger-line:nth-child(1) { top: 2px; }
  .hamburger-line:nth-child(2) { top: 8px; }

  #menu-toggle.is-open .hamburger-line:nth-child(1) {
    top: 5px;
    transform: rotate(45deg);
  }
  #menu-toggle.is-open .hamburger-line:nth-child(2) {
    top: 5px;
    transform: rotate(-45deg);
  }

  /* ─── Mobile menu overlay ─── */
  .mobile-menu {
    position: fixed;
    inset: 0;
    z-index: 55;
    pointer-events: none;
    visibility: hidden;
    overflow: hidden;
  }
  .mobile-menu-bg {
    position: absolute;
    inset: 0;
    background: #0C0B10;
    opacity: 0;
    transition: opacity 0.45s cubic-bezier(0.7, 0, 0.2, 1);
    will-change: opacity;
  }
  .mobile-menu-bg::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 80% 8%, rgba(0, 53, 176, 0.28), transparent 55%),
      radial-gradient(circle at 5% 95%, rgba(0, 53, 176, 0.16), transparent 50%);
    opacity: 0.9;
  }
  .mobile-menu-inner {
    position: relative;
    height: 100%;
    width: 100%;
    padding: 96px 28px 40px;
    display: flex;
    flex-direction: column;
    color: #FAFAFA;
    overflow-y: auto;
    overflow-x: hidden;
  }

  .mm-eyebrow {
    font-size: 10.5px;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(250, 250, 250, 0.4);
    margin-bottom: 1.75rem;
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 0.4s ease 0.15s, transform 0.5s cubic-bezier(0.2, 0.8, 0.2, 1) 0.15s;
  }

  .mm-list {
    list-style: none;
    padding: 0;
    margin: 0;
    border-top: 1px solid rgba(250, 250, 250, 0.08);
  }
  .mm-list li {
    border-bottom: 1px solid rgba(250, 250, 250, 0.08);
    opacity: 0;
    transform: translateY(14px);
    transition: opacity 0.5s ease, transform 0.55s cubic-bezier(0.2, 0.8, 0.2, 1);
    transition-delay: calc(0.15s + (var(--i) * 0.06s));
  }

  .mm-link {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    padding: 1.15rem 0.2rem;
    font-size: 1.95rem;
    font-weight: 600;
    letter-spacing: -0.025em;
    color: rgba(250, 250, 250, 0.92);
    position: relative;
    transition: color 0.25s ease, padding-left 0.35s cubic-bezier(0.2, 0.8, 0.2, 1);
  }
  .mm-link:active { color: #6b8ef0; }
  .mm-link:hover { padding-left: 0.5rem; }

  .mm-num {
    font-size: 10.5px;
    font-weight: 500;
    letter-spacing: 0.14em;
    color: rgba(250, 250, 250, 0.35);
    font-feature-settings: "tnum" on;
    position: relative;
    top: -0.55rem;
    min-width: 22px;
  }
  .mm-text { flex: 1; }
  .mm-arrow {
    opacity: 0;
    transform: translateX(-6px);
    color: rgba(250, 250, 250, 0.5);
    transition: opacity 0.3s ease, transform 0.35s cubic-bezier(0.2, 0.8, 0.2, 1);
  }
  .mm-link:hover .mm-arrow {
    opacity: 1;
    transform: translateX(0);
  }

  .mm-footer {
    margin-top: auto;
    padding-top: 2.25rem;
    opacity: 0;
    transform: translateY(10px);
    transition: opacity 0.5s ease 0.5s, transform 0.55s cubic-bezier(0.2, 0.8, 0.2, 1) 0.5s;
  }
  .mm-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.95rem 1.4rem;
    background: #0035B0;
    color: #FAFAFA;
    font-size: 13px;
    font-weight: 500;
    letter-spacing: -0.005em;
    transition: background-color 0.25s ease, transform 0.2s ease;
    box-shadow:
      inset 0 1px 0 0 rgba(255, 255, 255, 0.08),
      0 18px 36px -12px rgba(0, 53, 176, 0.6);
  }
  .mm-cta:active { background: #0040d4; transform: translateY(1px); }
  .mm-meta {
    margin-top: 1.1rem;
    font-size: 10.5px;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(250, 250, 250, 0.3);
  }

  /* Open state */
  .mobile-menu.is-open { pointer-events: auto; visibility: visible; }
  .mobile-menu.is-open .mobile-menu-bg { opacity: 1; }
  .mobile-menu.is-open .mm-eyebrow,
  .mobile-menu.is-open .mm-list li,
  .mobile-menu.is-open .mm-footer {
    opacity: 1;
    transform: translateY(0);
  }

  /* Respect reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .mm-eyebrow, .mm-list li, .mm-footer {
      transition: opacity 0.2s ease;
      transform: none;
    }
    .hamburger-line { transition: none; }
    .mobile-menu-bg { transition: opacity 0.2s ease; }
  }
</style>

<script>
  const toggleBtn = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const body = document.body;

  const setOpen = (open: boolean) => {
    if (!toggleBtn || !menu) return;
    toggleBtn.classList.toggle('is-open', open);
    toggleBtn.setAttribute('aria-expanded', String(open));
    toggleBtn.setAttribute('aria-label', open ? 'Fechar menu' : 'Abrir menu');
    menu.classList.toggle('is-open', open);
    menu.setAttribute('aria-hidden', String(!open));
    body.style.overflow = open ? 'hidden' : '';
  };

  toggleBtn?.addEventListener('click', () => {
    setOpen(!menu?.classList.contains('is-open'));
  });

  menu?.querySelectorAll<HTMLAnchorElement>('[data-menu-link]').forEach((link) => {
    link.addEventListener('click', () => setOpen(false));
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && menu?.classList.contains('is-open')) setOpen(false);
  });
</script>
