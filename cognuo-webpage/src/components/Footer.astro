---
const year = new Date().getFullYear();
---
<footer class="bg-secondary border-t border-white/6">
  <div class="max-w-7xl mx-auto px-6 lg:px-16 py-16">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-12 mb-14">
      <div class="col-span-2 md:col-span-1">
        <a href="/" aria-label="Cognuo">
          <img
            src="/images/logo_with_text_white.png"
            alt="Cognuo"
            class="h-5 w-auto mb-5"
            width="120"
            height="20"
            loading="lazy"
            decoding="async"
          />
        </a>
        <p class="text-sm text-[#FAFAFA]/35 leading-relaxed max-w-[200px]">
          Software house especializada em sistemas sob medida e automações com IA.
        </p>
      </div>

      <div>
        <p class="text-xs font-medium text-[#FAFAFA]/28 uppercase tracking-[0.15em] mb-5">Empresa</p>
        <ul class="space-y-3">
          <li><a href="/"         class="text-sm text-[#FAFAFA]/50 hover:text-[#FAFAFA] transition-colors">Início</a></li>
          <li><a href="#sobre"    class="text-sm text-[#FAFAFA]/50 hover:text-[#FAFAFA] transition-colors">Sobre</a></li>
          <li><a href="#processo" class="text-sm text-[#FAFAFA]/50 hover:text-[#FAFAFA] transition-colors">Processo</a></li>
          <li><a href="#cases"    class="text-sm text-[#FAFAFA]/50 hover:text-[#FAFAFA] transition-colors">Cases</a></li>
        </ul>
      </div>

      <div>
        <p class="text-xs font-medium text-[#FAFAFA]/28 uppercase tracking-[0.15em] mb-5">Soluções</p>
        <ul class="space-y-3">
          <li><a href="#solucoes" class="text-sm text-[#FAFAFA]/50 hover:text-[#FAFAFA] transition-colors">Automação com IA</a></li>
          <li><a href="#solucoes" class="text-sm text-[#FAFAFA]/50 hover:text-[#FAFAFA] transition-colors">Software sob medida</a></li>
          <li><a href="#solucoes" class="text-sm text-[#FAFAFA]/50 hover:text-[#FAFAFA] transition-colors">Agentes IA</a></li>
          <li><a href="#solucoes" class="text-sm text-[#FAFAFA]/50 hover:text-[#FAFAFA] transition-colors">Integrações</a></li>
          <li><a href="#solucoes" class="text-sm text-[#FAFAFA]/50 hover:text-[#FAFAFA] transition-colors">Sistemas internos</a></li>
        </ul>
      </div>

      <div>
        <p class="text-xs font-medium text-[#FAFAFA]/28 uppercase tracking-[0.15em] mb-5">Contato</p>
        <ul class="space-y-3">
          <li><a href="/contato" class="text-sm text-[#FAFAFA]/50 hover:text-[#FAFAFA] transition-colors">Falar com especialista</a></li>
          <li><a href="/contato" class="text-sm text-[#FAFAFA]/50 hover:text-[#FAFAFA] transition-colors">Agendar diagnóstico</a></li>
        </ul>
      </div>
    </div>

    <div class="pt-8 border-t border-white/6 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-3">
      <p class="text-xs text-[#FAFAFA]/22">&copy; {year} Cognuo. Todos os direitos reservados.</p>
      <p class="text-xs text-[#FAFAFA]/22">Brasil</p>
    </div>
  </div>
</footer>
